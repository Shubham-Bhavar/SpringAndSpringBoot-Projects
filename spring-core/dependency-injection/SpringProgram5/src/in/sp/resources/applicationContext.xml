<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.springframework.org/schema/beans 
    http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean class="in.sp.beans.Address" id="addId">
        <property name="houseno" value="108" />
        <property name="city" value="pune" />
        <property name="pincode" value="422601" />
    </bean>

    <bean class="in.sp.beans.Student" id="stdId">
        <property name="roll_no" value="8" />
        <property name="name" value="shubham" />
        <property name="address" ref="addId" />
    </bean>

</beans>