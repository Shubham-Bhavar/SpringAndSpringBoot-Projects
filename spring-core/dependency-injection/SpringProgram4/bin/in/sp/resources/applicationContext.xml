<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.springframework.org/schema/beans 
    http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean class="in.sp.beans.Address" id="addId">
        <constructor-arg value="234"></constructor-arg>
        <constructor-arg value="Pune"></constructor-arg>
        <constructor-arg value="422605"></constructor-arg>
    </bean>

    <bean class="in.sp.beans.Student" id="stdId">
        <constructor-arg value="08"></constructor-arg>
        <constructor-arg value="shubham"></constructor-arg>
        <constructor-arg ref="addId"></constructor-arg>
    </bean>

</beans>